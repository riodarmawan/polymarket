# Never commit the populated production environment file.
# Generate a NEW dedicated owner/session signer. Never reuse an exposed key.
POLYMARKET_OWNER_ADDRESS=0xreplace_me
POLYMARKET_PRIVATE_KEY=replace_me

# Public address that holds pUSD and outcome tokens. Fund this address, not the
# owner/session signer EOA. New integrations use signature type 3 (POLY_1271).
POLYMARKET_DEPOSIT_WALLET_ADDRESS=0xreplace_me
POLYMARKET_SIGNATURE_TYPE=3

# CLOB V2 L2 credentials for the new signer/deposit wallet.
POLYMARKET_CLOB_API_KEY=replace_me
POLYMARKET_CLOB_API_SECRET=replace_me
POLYMARKET_CLOB_PASSPHRASE=replace_me
POLYMARKET_CLOB_V2_URL=https://clob-v2.polymarket.com

# Relayer V2 credentials used for deposit-wallet deployment and approvals.
# Obtain from Polymarket Settings > API Keys > Relayer.
# Only RELAYER_API_KEY and RELAYER_API_KEY_ADDRESS are required for submit.
POLYMARKET_RELAYER_API_KEY=replace_me
POLYMARKET_RELAYER_API_KEY_ADDRESS=0xreplace_me
POLYMARKET_RELAYER_URL=https://polygon.api.relayer.polymarket.com
POLYMARKET_RPC_URL=https://polygon-rpc.example
POLYMARKET_CONFIG=/absolute/path/to/polymarket-bot/config/production.toml

# Fail-closed switch. Keep disabled until every runbook gate passes.
POLYMARKET_LIVE_TRADING_ENABLED=disabled
