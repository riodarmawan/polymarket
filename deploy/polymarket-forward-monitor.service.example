[Unit]
Description=Polymarket forward-test quality monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=polymarket
Group=polymarket
WorkingDirectory=/opt/polymarket/polymarket-bot
EnvironmentFile=/etc/polymarket/production.env
ExecStart=/opt/polymarket/polymarket-bot/target/release/polymarket-bot monitor-forward --max-iterations 1
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/polymarket/polymarket-bot/data-production
